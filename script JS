const container = document.querySelector('.container')
const count = document.getElementById('count')
const total = document.getElementById('total')
const movieSelect = document.getElementById('movie')
const showTime=document.getElementById("showTime")

let prices=[]

// create 25 seats per row

const rows = document.querySelectorAll('.row')
const rowLetters = ["A","B","C","D","E","F","G"]

rows.forEach((row,rowIndex)=>{

let label=row.querySelector(".label")

let start=rowLetters[rowIndex]+"1"
let end=rowLetters[rowIndex]+"25"

let type=""

if(row.classList.contains("regular")) type="Regular"
else if(row.classList.contains("prime")) type="Prime"
else if(row.classList.contains("primeplus")) type="Prime Plus"
else if(row.classList.contains("recliner")) type="Recliner"

label.textContent=`${type} (${start} to ${end})`

for(let i=1;i<=25;i++){

let seat=document.createElement("div")
seat.classList.add("seat")

seat.textContent=rowLetters[rowIndex]+i

row.appendChild(seat)

if(i===8 || i===17){
let gap=document.createElement("div")
gap.classList.add("aisle")
row.appendChild(gap)
}

}

})
// randomly make some seats occupied
const allSeats = document.querySelectorAll(".seat")

allSeats.forEach(seat => {

if(Math.random() < 0.2){   // about 20% seats occupied
seat.classList.add("occupied")
}

})

function calculatePrices(){

let range=movieSelect.value.split("-")

let min=parseInt(range[0])
let max=parseInt(range[1])

let step=(max-min)/3

prices=[
min,
Math.round(min+step),
Math.round(min+step*2),
max
]

updateTotal()

}

function updateTotal(){

let selectedSeats = container.querySelectorAll(".seat.selected")

// FIX: if no seats selected
if(selectedSeats.length === 0){
count.innerText = 0
total.innerText = 0
return
}

let totalPrice = 0

selectedSeats.forEach(seat=>{

let row=seat.parentElement

if(row.classList.contains("regular"))
totalPrice+=prices[0]

else if(row.classList.contains("prime"))
totalPrice+=prices[1]

else if(row.classList.contains("primeplus"))
totalPrice+=prices[2]

else if(row.classList.contains("recliner"))
totalPrice+=prices[3]

})

let selectedDate = new Date(dateInput.value)

if(dateInput.value){

let diff = (selectedDate - today) / (1000*60*60*24)

if(diff > 7){
totalPrice += 100
}

}

count.innerText = selectedSeats.length
total.innerText = totalPrice

}

container.addEventListener("click",e=>{

if(e.target.classList.contains("seat") && !e.target.classList.contains("occupied")){

e.target.classList.toggle("selected")
updateTotal()

}

})

movieSelect.addEventListener("change",calculatePrices)
const dateInput = document.getElementById("date")

let today = new Date()
let lastDate = new Date(today.getFullYear(),2,31) // March = 2 (0-index)

dateInput.min = today.toISOString().split("T")[0]
dateInput.max = lastDate.toISOString().split("T")[0]

calculatePrices()
function generateOccupiedSeats(){

const seats=document.querySelectorAll(".seat")

seats.forEach(seat=>{
seat.classList.remove("occupied")
})

seats.forEach(seat=>{

if(Math.random()<0.2){
seat.classList.add("occupied")
seat.classList.remove("selected")
}

})

updateTotal()

}
showTime.addEventListener("change",generateOccupiedSeats)
generateOccupiedSeats()
